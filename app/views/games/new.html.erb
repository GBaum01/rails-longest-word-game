<h1>Welcome to the longest word game!</h1>

<p>Your letters:</p>
<div class="letter-grid">
  <% @letters.each do |letter| %>
    <div class="tile"><%= letter %></div>
  <% end %>
</div>

<form action="/score" method="post" data-turbo="false">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

  <%= hidden_field_tag :letters, @letters.join(" ") %>
  <%= hidden_field_tag :start_time, @start_time %>

  <label>What's your longest word?</label>
  <input type="text" name="word">

  <input type="submit" value="Play">
</form>
